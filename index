  const colors2 = ['#00c8ff','#00e87a','#ffc300','#ff3b5c','#b06bff','#ff9500'];
  renderChart('ch-sml', {
    type:'scatter',
    data:{
      datasets:[
        {label:'SML',data:smlPoints,borderColor:'var(--text2)',borderWidth:1.5,pointRadius:0,showLine:true,borderDash:[4,4],type:'line'},
        ...valid.map((t,i)=>({
          label:t,
          data:[{x:betas[i],y:annRets[i]*100}],
          backgroundColor:colors2[i],
          pointRadius:7,pointHoverRadius:9
        })),
        {label:'Mercado',data:[{x:1,y:bmkAnn*100}],backgroundColor:'#fff',pointRadius:8,pointStyle:'rectRot'},
        {label:'Rf',data:[{x:0,y:RF*100}],backgroundColor:'#aaa',pointRadius:6},
      ]
    },
    options:{
      responsive:true,maintainAspectRatio:true,
      plugins:{legend:{labels:{color:'#5a7080',font:{size:10}}}},
      scales:{
        x:{title:{display:true,text:'Beta (β)',color:'#5a7080'},ticks:{color:'#5a7080',font:{size:10}},grid:{color:'rgba(255,255,255,.04)'}},
        y:{title:{display:true,text:'Retorno Anual (%)',color:'#5a7080'},ticks:{color:'#5a7080',font:{size:10},callback:v=>v.toFixed(1)+'%'},grid:{color:'rgba(255,255,255,.04)'}}
      }
    }
  });

  // Efficient frontier
  const pts = efficientFrontier(retArrays, valid, 2000);
  const maxS = pts.reduce((a,b)=>a.s>b.s?a:b);
  const minV = pts.reduce((a,b)=>a.v<b.v?a:b);
  renderChart('ch-frontier', {
    type:'scatter',
    data:{
      datasets:[
        {label:'Carteras MC',data:pts.map(p=>({x:p.v*100,y:p.r*100})),backgroundColor:pts.map(p=>`hsl(${(p.s+0.5)*200},80%,50%)`),pointRadius:1.5,pointHoverRadius:4},
        {label:'Máx Sharpe',data:[{x:maxS.v*100,y:maxS.r*100}],backgroundColor:'#ffc300',pointRadius:10,pointStyle:'star'},
        {label:'Mín Varianza',data:[{x:minV.v*100,y:minV.r*100}],backgroundColor:'#00c8ff',pointRadius:10,pointStyle:'triangle'},
        ...valid.map((t,i)=>({label:t,data:[{x:calcMetrics(retArrays[i]).annVol*100,y:calcMetrics(retArrays[i]).cagr*100}],backgroundColor:colors2[i],pointRadius:8}))
      ]
    },
    options:{
      responsive:true,maintainAspectRatio:true,
      plugins:{legend:{labels:{color:'#5a7080',font:{size:10}}}},
      scales:{
        x:{title:{display:true,text:'Volatilidad (%)',color:'#5a7080'},ticks:{color:'#5a7080',font:{size:10},callback:v=>v.toFixed(1)+'%'},grid:{color:'rgba(255,255,255,.04)'}},
        y:{title:{display:true,text:'Retorno (%)',color:'#5a7080'},ticks:{color:'#5a7080',font:{size:10},callback:v=>v.toFixed(1)+'%'},grid:{color:'rgba(255,255,255,.04)'}}
      }
    }
  });

  // Portfolio metrics
  const portRet = valid.reduce((s,t) => s+calcMetrics(state.data[t].returns).cagr*w, 0);
  const portVol = Math.sqrt(n===1 ? calcMetrics(retArrays[0]).annVol**2 :
    retArrays.reduce((s,a,i) => s + retArrays.reduce((s2,b,j) => s2 + w*w*correlation(a,b)*calcMetrics(a).annVol*calcMetrics(b).annVol, 0), 0));
  const portSharpe = (portRet-RF)/portVol;
  const portMetEl = document.getElementById('port-metrics');
  portMetEl.innerHTML = `
    <div class="card"><div class="card-t">RETORNO CARTERA</div><div class="card-v ${colCls(portRet)}">${fmtPct(portRet)}</div><div class="card-s">CAGR equiponderada</div></div>
