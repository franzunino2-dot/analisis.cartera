function runBacktest(ticker) {
  if(!ticker) ticker = state.tickers[0];
  if(!ticker || !state.data[ticker]) return;

  const d = state.data[ticker];
  const { prices, returns, dates } = d;
  const strat = document.getElementById('bt-strat')?.value || 'sma';
  const short = parseInt(document.getElementById('bt-s')?.value || 20);
  const long2  = parseInt(document.getElementById('bt-l')?.value || 50);
  const costBps = parseFloat(document.getElementById('bt-cost')?.value || 15);
  const cost = costBps / 10000;

  let result;
  let startOffset;
  if(strat === 'sma') {
    result = backtestSMA(prices, returns, short, long2, cost);
    startOffset = long2;
  } else if(strat === 'rsi') {
    result = backtestRSI(prices, returns, 14, 70, 30, cost);
    startOffset = 14;
  } else {
    result = backtestMomentum(prices, returns, 126, cost);
    startOffset = 126;
  }

  const {eq, bh} = result;
  const stratDates = dates.slice(startOffset);
  const stratRets = eq.map((v,i)=> i===0 ? 0 : v/eq[i-1]-1).slice(1);
  const bhRets = bh.map((v,i)=> i===0 ? 0 : v/bh[i-1]-1).slice(1);

  const ms = calcMetrics(stratRets);
  const mb = calcMetrics(bhRets);

  // Drawdown of strategy
  let peak=1, ddArr=[];
  for(const v of eq){ if(v>peak) peak=v; ddArr.push((v-peak)/peak*100); }

  // Metrics row
  const mrEl = document.getElementById('bt-metrics-row');
  if(mrEl) mrEl.innerHTML = `
    <div class="card"><div class="card-t">CAGR ESTRATEGIA</div><div class="card-v ${colCls(ms.cagr)}">${fmtPct(ms.cagr)}</div><div class="card-s">vs B&H: ${fmtPct(mb.cagr)}</div></div>
    <div class="card"><div class="card-t">SHARPE ESTRATEGIA</div><div class="card-v ${colCls(ms.sharpe)}">${fmt(ms.sharpe)}</div><div class="card-s">vs B&H: ${fmt(mb.sharpe)}</div></div>
    <div class="card"><div class="card-t">MAX DRAWDOWN</div><div class="card-v neg">${fmtPct(ms.mdd)}</div><div class="card-s">vs B&H: ${fmtPct(mb.mdd)}</div></div>
    <div class="card"><div class="card-t">RETORNO TOTAL</div><div class="card-v ${colCls(eq[eq.length-1]-1)}">${fmtPct(eq[eq.length-1]-1)}</div><div class="card-s">B&H: ${fmtPct(bh[bh.length-1]-1)}</div></div>
  `;

  // Equity chart
  renderChart('ch-equity', {
    type:'line',
    data:{
      labels: stratDates,
      datasets:[
        {label:'Estrategia',data:eq.map(v=>(v-1)*100),borderColor:'var(--accent)',borderWidth:1.8,pointRadius:0,tension:0.1},
        {label:'Buy & Hold',data:bh.map(v=>(v-1)*100),borderColor:'var(--green)',borderWidth:1.2,pointRadius:0,tension:0.1,borderDash:[4,4]},
      ]
    },
    options:{
      responsive:true,maintainAspectRatio:true,
      plugins:{legend:{labels:{color:'#5a7080',font:{size:11}}}},
      scales:{x:{ticks:{color:'#5a7080',maxTicksLimit:8,font:{size:9}},grid:{color:'rgba(255,255,255,.04)'}},y:{ticks:{color:'#5a7080',font:{size:10},callback:v=>v.toFixed(0)+'%'},grid:{color:'rgba(255,255,255,.04)'}}}
    }
  });

  // DD chart
  renderChart('ch-bt-dd', {
    type:'line',
    data:{
      labels: stratDates,
      datasets:[{label:'Drawdown',data:ddArr,borderColor:'var(--red)',borderWidth:1.2,pointRadius:0,fill:true,backgroundColor:'rgba(255,59,92,.15)',tension:0.1}]
    },
    options:{
      responsive:true,maintainAspectRatio:true,
      plugins:{legend:{display:false}},
      scales:{x:{ticks:{color:'#5a7080',maxTicksLimit:8,font:{size:9}},grid:{color:'rgba(255,255,255,.04)'}},y:{ticks:{color:'#5a7080',font:{size:10},callback:v=>v.toFixed(1)+'%'},grid:{color:'rgba(255,255,255,.04)'}}}
    }
  });

  // Detail table
  const stratName = strat==='sma'?`SMA(${short}/${long2})`:strat==='rsi'?'RSI (14, 30/70)':'Momentum 6m';
  const dtEl = document.getElementById('bt-detail-table');
  if(dtEl) dtEl.innerHTML = `
    <div class="card-t">TABLA DE PERFORMANCE — ${stratName} · Costos: ${costBps} bps/trade</div>
    <table class="tbl" style="margin-top:10px"><thead><tr>
      <th>MÉTRICA</th><th>ESTRATEGIA</th><th>BUY &amp; HOLD</th><th>DIFERENCIA</th>
    </tr></thead><tbody>
      ${[
        ['CAGR',fmtPct(ms.cagr),fmtPct(mb.cagr),fmtPct(ms.cagr-mb.cagr),ms.cagr-mb.cagr],
        ['Retorno Total',fmtPct(ms.total),fmtPct(mb.total),fmtPct(ms.total-mb.total),ms.total-mb.total],
        ['Vol Anual',fmtPct(ms.annVol),fmtPct(mb.annVol),fmtPct(ms.annVol-mb.annVol),mb.annVol-ms.annVol],
        ['Sharpe Ratio',fmt(ms.sharpe),fmt(mb.sharpe),fmt(ms.sharpe-mb.sharpe),ms.sharpe-mb.sharpe],
        ['Sortino Ratio',fmt(ms.sortino),fmt(mb.sortino),fmt(ms.sortino-mb.sortino),ms.sortino-mb.sortino],
        ['Max Drawdown',fmtPct(ms.mdd),fmtPct(mb.mdd),fmtPct(ms.mdd-mb.mdd),mb.mdd-ms.mdd],
        ['Calmar Ratio',ms.calmar?fmt(ms.calmar):'—',mb.calmar?fmt(mb.calmar):'—','—',0],
        ['Hit Ratio',fmtPct(ms.hits),fmtPct(mb.hits),fmtPct(ms.hits-mb.hits),ms.hits-mb.hits],
      ].map(([l,s2,b,diff,cv])=>`<tr>
        <td>${l}</td>
        <td class="${colCls(parseFloat(s2)||0)}">${s2}</td>
        <td>${b}</td>
        <td class="${colCls(cv)}">${diff}</td>
      </tr>`).join('')}
    </tbody></table>
  `;
}
</script>
</body>
</html>
