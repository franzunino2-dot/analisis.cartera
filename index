<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#060c18;--bg2:#0b1220;--bg3:#101826;--bg4:#151f2e;
  --border:#1c2e45;--accent:#00c8ff;--green:#00e87a;
  --red:#ff3b5c;--yellow:#ffc300;--purple:#b06bff;
  --text:#c5d3e0;--text2:#5a7080;--text3:#8a9bb0;
}
body{background:var(--bg);color:var(--text);font-family:'Courier New',monospace;font-size:13px;min-height:100vh}

/* ── HEADER ── */
.header{background:var(--bg2);border-bottom:2px solid var(--accent);padding:10px 20px;display:flex;align-items:center;gap:16px;flex-wrap:wrap}
.logo{color:var(--accent);font-size:15px;font-weight:bold;letter-spacing:3px;white-space:nowrap}
.logo em{color:var(--green);font-style:normal}
.search-row{display:flex;gap:8px;align-items:center;flex:1;flex-wrap:wrap}
input[type=text]{background:var(--bg3);border:1px solid var(--border);color:var(--accent);padding:7px 12px;font-family:inherit;font-size:13px;text-transform:uppercase;outline:none;width:110px;letter-spacing:2px}
input[type=text]:focus{border-color:var(--accent);box-shadow:0 0 8px rgba(0,200,255,.2)}
select{background:var(--bg3);border:1px solid var(--border);color:var(--text);padding:7px 10px;font-family:inherit;font-size:12px;outline:none;cursor:pointer}
.btn{background:transparent;border:1px solid var(--accent);color:var(--accent);padding:6px 14px;cursor:pointer;font-family:inherit;font-size:12px;letter-spacing:1px;transition:.2s}
.btn:hover{background:var(--accent);color:var(--bg)}
.btn-g{border-color:var(--green);color:var(--green)}
.btn-g:hover{background:var(--green);color:var(--bg)}
.btn-r{border-color:var(--red);color:var(--red)}
.btn-r:hover{background:var(--red);color:#fff}
.btn-y{border-color:var(--yellow);color:var(--yellow)}
.btn-y:hover{background:var(--yellow);color:var(--bg)}

/* ── PORTFOLIO BAR ── */
.port-bar{background:var(--bg2);border-bottom:1px solid var(--border);padding:8px 20px;display:flex;gap:8px;align-items:center;flex-wrap:wrap;min-height:42px}
.chip{background:var(--bg4);border:1px solid var(--border);padding:4px 10px;display:inline-flex;align-items:center;gap:8px;font-size:12px;cursor:default}
.chip .ct{color:var(--accent);font-weight:bold;letter-spacing:1px}
.chip .cw{color:var(--yellow)}
.chip .cx{color:var(--red);cursor:pointer;font-size:14px;line-height:1}
.chip .cx:hover{color:#ff0}
.port-label{color:var(--text2);font-size:11px;letter-spacing:1px}

/* ── TABS ── */
.tabs{display:flex;background:var(--bg2);border-bottom:1px solid var(--border);overflow-x:auto}
.tab{padding:10px 18px;cursor:pointer;border-bottom:2px solid transparent;color:var(--text2);font-size:11px;letter-spacing:2px;white-space:nowrap;transition:.2s}
.tab:hover{color:var(--text)}
.tab.active{border-bottom-color:var(--accent);color:var(--accent)}

/* ── CONTENT ── */
