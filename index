<script>
// ═══════════════════════════════════════════════════
// CONFIG
// ═══════════════════════════════════════════════════
const API_KEY = 'ATs53ltdtP1XcU7YnooOEDzwgRQk737E';
const BASE    = 'https://financialmodelingprep.com/api/v3';
const RF      = 0.045; // tasa libre de riesgo anual

// State
let state = {
  tickers: [],
  data: {},      // {ticker: {prices, returns, quote, profile}}
  spy: null,     // benchmark returns
  charts: {},    // chart instances
  activeTab: 'resumen'
};

// Status bar clock
setInterval(() => {
  document.getElementById('sb-time').innerHTML =
    'HORA: <b>' + new Date().toLocaleTimeString('es-AR') + '</b>';
}, 1000);

// ═══════════════════════════════════════════════════
// UI HELPERS
// ═══════════════════════════════════════════════════
function switchTab(t) {
  state.activeTab = t;
  document.querySelectorAll('.tab').forEach((el,i) => {
    const tabs = ['resumen','tecnico','riesgo','optimizacion','backtest'];
    el.classList.toggle('active', tabs[i] === t);
  });
  document.querySelectorAll('.panel').forEach(el => el.classList.remove('active'));
  document.getElementById('panel-' + t).classList.add('active');
}

function setStatus(msg, color='var(--text2)') {
  const el = document.getElementById('status-msg');
  el.style.color = color;
  el.textContent = msg;
}

function fmt(v, dec=2) { return v == null ? '—' : Number(v).toFixed(dec); }
function fmtPct(v, dec=2) { if(v==null) return '—'; const s=Number(v)*100; return (s>=0?'+':'')+s.toFixed(dec)+'%'; }
function fmtM(v) { if(!v) return '—'; if(v>1e12) return '$'+(v/1e12).toFixed(2)+'T'; if(v>1e9) return '$'+(v/1e9).toFixed(2)+'B'; if(v>1e6) return '$'+(v/1e6).toFixed(2)+'M'; return '$'+v.toFixed(0); }
function colCls(v) { return v > 0 ? 'pos' : v < 0 ? 'neg' : 'neu'; }
function colStr(v) { return v > 0 ? 'var(--green)' : v < 0 ? 'var(--red)' : 'var(--yellow)'; }
function destroyChart(id) { if(state.charts[id]) { state.charts[id].destroy(); delete state.charts[id]; } }

function renderChart(id, config) {
  destroyChart(id);
  const ctx = document.getElementById(id)?.getContext('2d');
  if(!ctx) return;
  state.charts[id] = new Chart(ctx, config);
}

// ═══════════════════════════════════════════════════
// PORTFOLIO MANAGEMENT
// ═══════════════════════════════════════════════════
function addTicker() {
  const val = document.getElementById('ticker-input').value.trim().toUpperCase();
  if(!val) return;
  if(state.tickers.includes(val)) { setStatus('Ya está en la cartera', 'var(--yellow)'); return; }
  if(state.tickers.length >= 6) { setStatus('Máximo 6 tickers', 'var(--red)'); return; }
  state.tickers.push(val);
  document.getElementById('ticker-input').value = '';
  renderPortBar();
  setStatus(val + ' agregado', 'var(--green)');
}

function removeTicker(t) {
  state.tickers = state.tickers.filter(x => x !== t);
  delete state.data[t];
  renderPortBar();
}

function clearAll() {
  state.tickers = [];
  state.data = {};
  state.spy = null;
  renderPortBar();
  ['resumen','tecnico','riesgo','optimizacion','backtest'].forEach(t =>
    document.getElementById('panel-'+t).innerHTML = '<div class="empty">Ingresá un ticker y hacé click en <b style="color:var(--accent)">▶ ANALIZAR</b></div>'
  );
  setStatus('');
}

function renderPortBar() {
  const bar = document.getElementById('port-bar');
  if(!state.tickers.length) {
    bar.innerHTML = '<span class="port-label">CARTERA →</span><span style="color:var(--text2);font-size:11px">Ingresá un ticker y hacé click en + AGREGAR</span>';
    return;
  }
  const w = Math.round(100 / state.tickers.length);
  bar.innerHTML = '<span class="port-label">CARTERA →</span>' +
    state.tickers.map(t =>
      `<div class="chip">
        <span class="ct">${t}</span>
        <span class="cw">${w}%</span>
        <span class="cx" onclick="removeTicker('${t}')">✕</span>
      </div>`
    ).join('') +
    `<span style="color:var(--text2);font-size:11px;margin-left:8px">Peso uniforme · Total: ${state.tickers.length} activos</span>`;
}

document.getElementById('ticker-input').addEventListener('keydown', e => {
  if(e.key === 'Enter') addTicker();
});

// ═══════════════════════════════════════════════════
// API CALLS
// ═══════════════════════════════════════════════════
async function fetchQuote(ticker) {
  const r = await fetch(`${BASE}/quote/${ticker}?apikey=${API_KEY}`);
  const d = await r.json();
  return d[0] || null;
}

async function fetchHistory(ticker, fromDate) {
  const r = await fetch(`${BASE}/historical-price-full/${ticker}?from=${fromDate}&apikey=${API_KEY}`);
  const d = await r.json();
  if(!d.historical) return null;
  // reverse to chronological order
  return d.historical.slice().reverse();
}

async function fetchProfile(ticker) {
  const r = await fetch(`${BASE}/profile/${ticker}?apikey=${API_KEY}`);
  const d = await r.json();
  return d[0] || null;
}

// ═══════════════════════════════════════════════════
// CALCULATIONS
// ═══════════════════════════════════════════════════

// Daily arithmetic returns
function calcReturns(closes) {
  const ret = [];
  for(let i=1;i<closes.length;i++) ret.push((closes[i]-closes[i-1])/closes[i-1]);
  return ret;
}

// EMA
function calcEMA(data, period) {
  const k = 2/(period+1);
  const ema = [data[0]];
  for(let i=1;i<data.length;i++) ema.push(data[i]*k + ema[i-1]*(1-k));
  return ema;
}

// RSI (Wilder)
function calcRSI(closes, period=14) {
  const rsi=[], gains=[], losses=[];
  for(let i=1;i<closes.length;i++){
    const d=closes[i]-closes[i-1];
    gains.push(d>0?d:0); losses.push(d<0?-d:0);
  }
  let ag=gains.slice(0,period).reduce((a,b)=>a+b)/period;
  let al=losses.slice(0,period).reduce((a,b)=>a+b)/period;
  rsi.push(al===0?100:100-100/(1+ag/al));
  for(let i=period;i<gains.length;i++){
    ag=(ag*(period-1)+gains[i])/period;
    al=(al*(period-1)+losses[i])/period;
    rsi.push(al===0?100:100-100/(1+ag/al));
  }
  return rsi;
}

// MACD
function calcMACD(closes, fast=12, slow=26, sig=9) {
  const ef=calcEMA(closes,fast), es=calcEMA(closes,slow);
  const macd=ef.map((v,i)=>v-es[i]).slice(slow-1);
  const signal=calcEMA(macd,sig);
  const hist=macd.map((v,i)=>i<sig-1?null:v-signal[i-(sig-1)]);
  return {macd, signal, hist};
}

// Bollinger Bands
function calcBollinger(closes, period=20, mult=2) {
  const mid=[],up=[],dn=[];
  for(let i=period;i<=closes.length;i++){
    const sl=closes.slice(i-period,i);
    const m=sl.reduce((a,b)=>a+b)/period;
    const sd=Math.sqrt(sl.reduce((a,b)=>a+(b-m)**2,0)/period);
    mid.push(m); up.push(m+mult*sd); dn.push(m-mult*sd);
  }
  return {mid,up,dn};
}

// Stochastic %K
function calcStochastic(closes, highs, lows, period=14, smoothK=3) {
  const k=[];
  for(let i=period-1;i<closes.length;i++){
    const h=Math.max(...highs.slice(i-period+1,i+1));
    const l=Math.min(...lows.slice(i-period+1,i+1));
    k.push(h===l?50:((closes[i]-l)/(h-l))*100);
  }
  // smooth %K
  const sk=[];
  for(let i=smoothK-1;i<k.length;i++) sk.push(k.slice(i-smoothK+1,i+1).reduce((a,b)=>a+b)/smoothK);
  const sd=calcEMA(sk,3); // %D
  return {k:sk,d:sd};
}

// CCI
function calcCCI(closes, highs, lows, period=20) {
  const cci=[];
  for(let i=period-1;i<closes.length;i++){
    const tp=closes.slice(i-period+1,i+1).map((_,j)=>(highs[i-period+1+j]+lows[i-period+1+j]+closes[i-period+1+j])/3);
    const m=tp.reduce((a,b)=>a+b)/period;
    const md=tp.reduce((a,b)=>a+Math.abs(b-m),0)/period;
    cci.push(md===0?0:(tp[tp.length-1]-m)/(0.015*md));
  }
  return cci;
}

// OBV
function calcOBV(closes, volumes) {
  const obv=[0];
  for(let i=1;i<closes.length;i++){
    const prev=obv[i-1];
    if(closes[i]>closes[i-1]) obv.push(prev+volumes[i]);
    else if(closes[i]<closes[i-1]) obv.push(prev-volumes[i]);
    else obv.push(prev);
  }
  return obv;
}

// Momentum (Rate of Change)
function calcMomentum(closes, period=14) {
  const m=[];
  for(let i=period;i<closes.length;i++) m.push((closes[i]/closes[i-period]-1)*100);
  return m;
}

// VaR calculations
function calcVaR(returns, confidence=0.95, capital=1000000, horizon=1) {
  const n=returns.length;
  const mean=returns.reduce((a,b)=>a+b)/n;
  const std=Math.sqrt(returns.reduce((a,b)=>a+(b-mean)**2,0)/n);
  // Normal quantile (PPF)
  const z=confidence===0.99?-2.3263:-1.6449;
  const muT=mean*horizon, sigT=std*Math.sqrt(horizon);
  const varP=-(muT+z*sigT)*capital;

  // Historical
  const sorted=[...returns].sort((a,b)=>a-b);
  const idx=Math.floor((1-confidence)*n);
  const varH=-sorted[idx]*capital*Math.sqrt(horizon);

  // CVaR
  const tail=sorted.slice(0,idx);
  const cvarH=tail.length?-tail.reduce((a,b)=>a+b)/tail.length*capital*Math.sqrt(horizon):varH*1.3;

  // Monte Carlo VaR
  const sims=[];
  for(let i=0;i<10000;i++){
    const u1=Math.random(),u2=Math.random();
    const z2=Math.sqrt(-2*Math.log(u1))*Math.cos(2*Math.PI*u2);
    sims.push(mean+std*z2);
  }
  sims.sort((a,b)=>a-b);
  const varMC=-sims[Math.floor((1-confidence)*sims.length)]*capital*Math.sqrt(horizon);

  return {varP, varH, varMC, cvarH, mean, std};
}

// Risk metrics
function calcMetrics(returns) {
  const n=returns.length;
  const mean=returns.reduce((a,b)=>a+b)/n;
  const std=Math.sqrt(returns.reduce((a,b)=>a+(b-mean)**2,0)/n);
  const annRet=(1+mean)**252-1;
  const annVol=std*Math.sqrt(252);
  const sharpe=(annRet-RF)/annVol;
  const rfDaily=RF/252;
  const down=returns.filter(r=>r<rfDaily);
  const dsVol=down.length?Math.sqrt(down.reduce((a,b)=>a+(b-rfDaily)**2,0)/down.length)*Math.sqrt(252):annVol;
  const sortino=(annRet-RF)/dsVol;
  // Cumulative for drawdown
  let cum=1,peak=1,mdd=0;
  const cumArr=[1],ddArr=[0];
  for(const r of returns){
    cum*=(1+r); cumArr.push(cum);
    if(cum>peak) peak=cum;
    const dd=(cum-peak)/peak;
    if(dd<mdd) mdd=dd;
    ddArr.push(dd);
  }
  const total=cum-1;
  const yrs=n/252;
  const cagr=cum**(1/yrs)-1;
  const calmar=mdd<0?cagr/Math.abs(mdd):null;
  const hits=returns.filter(r=>r>0).length/n;
  return {annRet,annVol,sharpe,sortino,mdd,cagr,calmar,hits,total,cumArr,ddArr};
}

// Beta & Alpha (CAPM)
function calcBeta(assetRet, bmkRet) {
  const n=Math.min(assetRet.length,bmkRet.length);
  const a=assetRet.slice(-n), b=bmkRet.slice(-n);
  const ma=a.reduce((s,v)=>s+v)/n, mb=b.reduce((s,v)=>s+v)/n;
  const cov=a.reduce((s,v,i)=>s+(v-ma)*(b[i]-mb),0)/n;
  const vb=b.reduce((s,v)=>s+(v-mb)**2,0)/n;
  const beta=cov/vb;
  const alphaD=ma-beta*mb;
  const alphaA=alphaD*252;
  return {beta,alphaA};
}

// Pearson correlation
function correlation(a, b) {
  const n=Math.min(a.length,b.length);
  const x=a.slice(-n), y=b.slice(-n);
  const mx=x.reduce((s,v)=>s+v)/n, my=y.reduce((s,v)=>s+v)/n;
  const num=x.reduce((s,v,i)=>s+(v-mx)*(y[i]-my),0);
  const dx=Math.sqrt(x.reduce((s,v)=>s+(v-mx)**2,0));
  const dy=Math.sqrt(y.reduce((s,v)=>s+(v-my)**2,0));
  return num/(dx*dy||1);
}

// SMA Backtest
function backtestSMA(prices, returns, s=20, l=50, cost=0.0015) {
  const eq=[1], bh=[1];
  let pos=0, dates=[];
  for(let i=l;i<prices.length-1;i++){
    const sma=prices.slice(i-s,i).reduce((a,b)=>a+b)/s;
    const lma=prices.slice(i-l,i).reduce((a,b)=>a+b)/l;
    const newPos=sma>lma?1:-1;
    const ret=returns[i]||0;
    let sret=newPos*ret;
    if(newPos!==pos){sret-=cost;pos=newPos;}
    eq.push(eq[eq.length-1]*(1+sret));
    bh.push(bh[bh.length-1]*(1+ret));
  }
  return {eq,bh};
}

// RSI Backtest
function backtestRSI(prices, returns, period=14, ob=70, os=30, cost=0.0015) {
  const rsi=calcRSI(prices,period);
  const startIdx=period;
  const eq=[1], bh=[1];
  let pos=0;
  for(let i=0;i<rsi.length-1;i++){
    const r=rsi[i], ret=returns[startIdx+i]||0;
    let newPos=pos;
    if(pos===0&&r<os) newPos=1;
    else if(pos===1&&r>ob) newPos=0;
    let sret=newPos*ret;
    if(newPos!==pos){sret-=cost;pos=newPos;}
    eq.push(eq[eq.length-1]*(1+sret));
    bh.push(bh[bh.length-1]*(1+ret));
  }
  return {eq,bh};
}

// Momentum Backtest
function backtestMomentum(prices, returns, win=126, cost=0.0015) {
  const eq=[1], bh=[1];
  let pos=0;
  for(let i=win;i<prices.length-1;i++){
    const mom=prices[i]/prices[i-win]-1;
    const newPos=mom>0?1:-1;
    const ret=returns[i]||0;
    let sret=newPos*ret;
    if(newPos!==pos){sret-=cost;pos=newPos;}
    eq.push(eq[eq.length-1]*(1+sret));
    bh.push(bh[bh.length-1]*(1+ret));
  }
  return {eq,bh};
}

// Efficient frontier (Monte Carlo)
function efficientFrontier(retArrays, tickers, nsim=3000) {
  const n=retArrays.length;
  const annR=retArrays.map(r=>{const m=r.reduce((a,b)=>a+b)/r.length;return (1+m)**252-1;});
  // Cov matrix (annualized)
  const cov=[];
  for(let i=0;i<n;i++){
    cov[i]=[];
    for(let j=0;j<n;j++){
      const L=Math.min(retArrays[i].length,retArrays[j].length);
      const a=retArrays[i].slice(-L),b=retArrays[j].slice(-L);
      const ma=a.reduce((s,v)=>s+v)/L, mb=b.reduce((s,v)=>s+v)/L;
      cov[i][j]=a.reduce((s,v,k)=>s+(v-ma)*(b[k]-mb),0)/L*252;
    }
  }
  const pts=[];
  for(let p=0;p<nsim;p++){
    const w=new Array(n).fill(0).map(()=>Math.random());
    const ws=w.reduce((a,b)=>a+b);
    const wn=w.map(v=>v/ws);
    const r=wn.reduce((s,wi,i)=>s+wi*annR[i],0);
    let v=0;
    for(let i=0;i<n;i++) for(let j=0;j<n;j++) v+=wn[i]*wn[j]*cov[i][j];
    pts.push({r,v:Math.sqrt(v),s:(r-RF)/Math.sqrt(v),w:wn});
  }
  return pts;
}

// Return distribution (histogram buckets)
function histogram(returns, bins=30) {
  const mn=Math.min(...returns), mx=Math.max(...returns);
  const bw=(mx-mn)/bins;
  const counts=new Array(bins).fill(0);
  const labels=[];
  for(let i=0;i<bins;i++) labels.push(((mn+i*bw)*100).toFixed(2)+'%');
  for(const r of returns){
    const idx=Math.min(Math.floor((r-mn)/bw),bins-1);
    counts[idx]++;
  }
  return {counts,labels,mn,mx,bw};
}

// Hurst exponent
function calcHurst(prices) {
  const logs=prices.map(p=>Math.log(p));
  const n=logs.length;
  if(n<30) return null;
  const ranges=[8,16,32,Math.min(64,n)];
  const pts=[];
  for(const r of ranges){
    const chunks=Math.floor(n/r);
    let rs=0;
    for(let c=0;c<chunks;c++){
      const sl=logs.slice(c*r,(c+1)*r);
      const m=sl.reduce((a,b)=>a+b)/r;
      const dev=sl.map((_,i)=>sl.slice(0,i+1).reduce((a,b)=>a+b)/(i+1)-m);
      const R=Math.max(...dev)-Math.min(...dev);
      const S=Math.sqrt(sl.reduce((a,v)=>a+(v-m)**2,0)/r);
      if(S>0) rs+=R/S;
    }
    if(rs>0) pts.push({x:Math.log(r),y:Math.log(rs/chunks)});
  }
  if(pts.length<2) return 0.5;
  const mx=pts.reduce((a,b)=>a+b.x,0)/pts.length;
  const my=pts.reduce((a,b)=>a+b.y,0)/pts.length;
  const num=pts.reduce((a,p)=>a+(p.x-mx)*(p.y-my),0);
  const den=pts.reduce((a,p)=>a+(p.x-mx)**2,0);
  return num/den;
}

