async function analyze() {
  if(!state.tickers.length) { setStatus('Agregá al menos un ticker', 'var(--red)'); return; }
  setStatus('⏳ Cargando datos...', 'var(--accent)');

  // Date 1 year ago
  const from = new Date();
  from.setFullYear(from.getFullYear()-1);
  const fromStr = from.toISOString().split('T')[0];

  try {
    // Fetch all tickers + SPY
    const allSymbols = [...new Set([...state.tickers, 'SPY'])];
    const fetches = allSymbols.map(async t => {
      const [hist, quote, profile] = await Promise.all([
        fetchHistory(t, fromStr),
        fetchQuote(t),
        fetchProfile(t)
      ]);
      return {t, hist, quote, profile};
    });

    const results = await Promise.all(fetches);

    results.forEach(({t, hist, quote, profile}) => {
      if(!hist || hist.length < 20) return;
      const prices  = hist.map(d => d.adjClose || d.close);
      const highs   = hist.map(d => d.high);
      const lows    = hist.map(d => d.low);
      const volumes = hist.map(d => d.volume);
      const dates   = hist.map(d => d.date);
      const returns = calcReturns(prices);

      if(t === 'SPY') {
        state.spy = returns;
      } else {
        state.data[t] = {prices, highs, lows, volumes, dates, returns, quote, profile};
      }
    });

    setStatus('✓ Datos cargados', 'var(--green)');
    renderAll();
  } catch(e) {
    setStatus('Error: ' + e.message, 'var(--red)');
    console.error(e);
  }
}

function renderAll() {
  const tickers = state.tickers.filter(t => state.data[t]);
