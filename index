  // Portfolio summary
  html += `<div class="stitle">MÉTRICAS DE CARTERA EQUIPONDERADA</div>
  <div class="g4" id="port-metrics"></div>`;

  el.innerHTML = html;

  const retArrays = valid.map(t => state.data[t].returns);
  const n = valid.length;
  const w = 1/n;

  // Correlation matrix render
  const corrEl = document.getElementById('hm-wrap');
  const corrMatrix = [];
  for(let i=0;i<n;i++){
    corrMatrix[i]=[];
    for(let j=0;j<n;j++) corrMatrix[i][j] = i===j?1:correlation(retArrays[i],retArrays[j]);
  }
  // Build heatmap table
  let hm = `<table style="border-collapse:collapse;margin-top:10px;font-size:11px">`;
  hm += '<tr><td></td>' + valid.map(t => `<td style="text-align:center;padding:4px 6px;color:var(--text2);font-weight:bold">${t}</td>`).join('') + '</tr>';
  for(let i=0;i<n;i++){
    hm += `<tr><td style="padding:4px 8px;color:var(--text3);text-align:right">${valid[i]}</td>`;
    for(let j=0;j<n;j++){
      const v=corrMatrix[i][j];
      const r=Math.round(255*(v>0?(1-v):1));
      const g=Math.round(255*(v>0?1:1-Math.abs(v)));
      const b=Math.round(255*(v<0?(1+v):0));
      const bg=`rgba(${r},${g},${b},0.6)`;
      const tc = Math.abs(v)>0.5?'#000':'#fff';
      hm += `<td style="background:${bg};color:${tc};padding:4px 6px;text-align:center;font-weight:bold;border:1px solid rgba(0,0,0,.2)">${fmt(v)}</td>`;
    }
    hm += '</tr>';
  }
  hm += '</table>';
  corrEl.innerHTML = hm;

  // CAPM table
  const bmkRet = state.spy;
  const bmkAnn = bmkRet ? (1+bmkRet.reduce((a,b)=>a+b)/bmkRet.length)**252-1 : 0.10;
  const tbody = document.getElementById('capm-tbody');
  const betas=[], alphas=[], annRets=[];
  valid.forEach(t => {
    const td2 = state.data[t];
    const m = calcMetrics(td2.returns);
    const {beta,alphaA} = bmkRet ? calcBeta(td2.returns,bmkRet) : {beta:1,alphaA:0};
    const capmR = RF + beta*(bmkAnn-RF);
    const excess = m.cagr - capmR;
    betas.push(beta); alphas.push(alphaA); annRets.push(m.cagr);
    tbody.innerHTML += `<tr>
