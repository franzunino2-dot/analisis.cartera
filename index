function calcSkewness(arr) {
  const n=arr.length, m=arr.reduce((a,b)=>a+b)/n;
  const s=Math.sqrt(arr.reduce((a,b)=>a+(b-m)**2,0)/n);
  return arr.reduce((a,b)=>a+((b-m)/s)**3,0)/n;
}
function calcKurtosis(arr) {
  const n=arr.length, m=arr.reduce((a,b)=>a+b)/n;
  const s=Math.sqrt(arr.reduce((a,b)=>a+(b-m)**2,0)/n);
  return arr.reduce((a,b)=>a+((b-m)/s)**4,0)/n-3;
}

